<?xml version="1.0" encoding="UTF-8"?>
<ui version="4.0">
	<class>NewProjectWidget</class>
	<widget class="QWidget" name="NewProjectWidget">

		<property name="geometry">
			<rect>
				<x>0</x>
				<y>0</y>
				<width>700</width>
				<height>500</height>
			</rect>
		</property>

		<!-- Root vertical layout: mirrors the outer StackPanel (Vertical) -->
		<layout class="QVBoxLayout" name="rootLayout">
			<property name="spacing">
				<number>0</number>
			</property>
			<property name="leftMargin">
				<number>32</number>
			</property>
			<property name="topMargin">
				<number>32</number>
			</property>
			<property name="rightMargin">
				<number>32</number>
			</property>
			<property name="bottomMargin">
				<number>32</number>
			</property>

			<!-- ── Row 1: Template selector + Preview pane ──────────────────── -->
			<!-- Mirrors: <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"> -->
			<item>
				<layout class="QHBoxLayout" name="templateRow">
					<property name="spacing">
						<number>8</number>
					</property>

					<!-- Centering spacer (left) — equivalent to HorizontalAlignment="Center" -->
					<item>
						<spacer name="templateLeftSpacer">
							<property name="orientation">
								<enum>Qt::Orientation::Horizontal</enum>
							</property>
							<property name="sizeHint" stdset="0">
								<size>
									<width>40</width>
									<height>20</height>
								</size>
							</property>
						</spacer>
					</item>

					<!-- ListBox → QListWidget: shows available project templates -->
					<item>
						<widget class="QListWidget" name="templateList">
							<property name="minimumWidth">
								<number>195</number>
							</property>
							<property name="maximumWidth">
								<number>195</number>
							</property>
							<property name="minimumHeight">
								<number>250</number>
							</property>
							<property name="maximumHeight">
								<number>250</number>
							</property>
						</widget>
					</item>

					<!-- Border → QFrame: preview / thumbnail of the selected template -->
					<item>
						<widget class="QFrame" name="previewPane">
							<property name="minimumWidth">
								<number>400</number>
							</property>
							<property name="maximumWidth">
								<number>400</number>
							</property>
							<property name="minimumHeight">
								<number>250</number>
							</property>
							<property name="maximumHeight">
								<number>250</number>
							</property>
							<!-- Box frame gives the Border-like stroke appearance -->
							<property name="frameShape">
								<enum>QFrame::Shape::Box</enum>
							</property>
							<property name="frameShadow">
								<enum>QFrame::Shadow::Plain</enum>
							</property>
						</widget>
					</item>

					<!-- Centering spacer (right) -->
					<item>
						<spacer name="templateRightSpacer">
							<property name="orientation">
								<enum>Qt::Orientation::Horizontal</enum>
							</property>
							<property name="sizeHint" stdset="0">
								<size>
									<width>40</width>
									<height>20</height>
								</size>
							</property>
						</spacer>
					</item>
				</layout>
			</item>

			<!-- Spacing between template row and form rows (mirrors Margin="0,30,0,0") -->
			<item>
				<spacer name="spacer1">
					<property name="orientation">
						<enum>Qt::Orientation::Vertical</enum>
					</property>
					<property name="sizeType">
						<enum>QSizePolicy::Policy::Fixed</enum>
					</property>
					<property name="sizeHint" stdset="0">
						<size>
							<width>20</width>
							<height>30</height>
						</size>
					</property>
				</spacer>
			</item>

			<!-- ── Row 2: Project Name ───────────────────────────────────────── -->
			<!-- Mirrors: TextBlock "Name" + TextBox Width="550" -->
			<item>
				<layout class="QHBoxLayout" name="nameRow">
					<property name="spacing">
						<number>8</number>
					</property>

					<item>
						<spacer name="nameLeftSpacer">
							<property name="orientation">
								<enum>Qt::Orientation::Horizontal</enum>
							</property>
							<property name="sizeHint" stdset="0">
								<size>
									<width>40</width>
									<height>20</height>
								</size>
							</property>
						</spacer>
					</item>

					<item>
						<widget class="QLabel" name="labelName">
							<property name="text">
								<string>Name</string>
							</property>
							<property name="minimumWidth">
								<number>50</number>
							</property>
							<property name="maximumWidth">
								<number>50</number>
							</property>
							<!-- Align right so the colon sits flush against the input field -->
							<property name="alignment">
								<set>Qt::AlignmentFlag::AlignRight|Qt::AlignmentFlag::AlignVCenter</set>
							</property>
						</widget>
					</item>

					<item>
						<widget class="QLineEdit" name="inputName">
							<property name="minimumWidth">
								<number>550</number>
							</property>
							<property name="maximumWidth">
								<number>550</number>
							</property>
							<property name="placeholderText">
								<string>MyProject</string>
							</property>
						</widget>
					</item>

					<item>
						<spacer name="nameRightSpacer">
							<property name="orientation">
								<enum>Qt::Orientation::Horizontal</enum>
							</property>
							<property name="sizeHint" stdset="0">
								<size>
									<width>40</width>
									<height>20</height>
								</size>
							</property>
						</spacer>
					</item>
				</layout>
			</item>

			<!-- Spacing (mirrors Margin="0,30,0,0") -->
			<item>
				<spacer name="spacer2">
					<property name="orientation">
						<enum>Qt::Orientation::Vertical</enum>
					</property>
					<property name="sizeType">
						<enum>QSizePolicy::Policy::Fixed</enum>
					</property>
					<property name="sizeHint" stdset="0">
						<size>
							<width>20</width>
							<height>16</height>
						</size>
					</property>
				</spacer>
			</item>

			<!-- ── Row 3: Project Path ───────────────────────────────────────── -->
			<!-- Mirrors: TextBlock "Path" + TextBox Width="550" + Button "Browse" -->
			<item>
				<layout class="QHBoxLayout" name="pathRow">
					<property name="spacing">
						<number>8</number>
					</property>

					<item>
						<spacer name="pathLeftSpacer">
							<property name="orientation">
								<enum>Qt::Orientation::Horizontal</enum>
							</property>
							<property name="sizeHint" stdset="0">
								<size>
									<width>40</width>
									<height>20</height>
								</size>
							</property>
						</spacer>
					</item>

					<item>
						<widget class="QLabel" name="labelPath">
							<property name="text">
								<string>Path</string>
							</property>
							<property name="minimumWidth">
								<number>50</number>
							</property>
							<property name="maximumWidth">
								<number>50</number>
							</property>
							<property name="alignment">
								<set>Qt::AlignmentFlag::AlignRight|Qt::AlignmentFlag::AlignVCenter</set>
							</property>
						</widget>
					</item>

					<item>
						<widget class="QLineEdit" name="inputPath">
							<property name="minimumWidth">
								<number>550</number>
							</property>
							<property name="maximumWidth">
								<number>550</number>
							</property>
							<property name="placeholderText">
								<string>C:/Projects/</string>
							</property>
						</widget>
					</item>

					<!-- Button "Browse" (Width="45") — opens a QFileDialog in the .cpp -->
					<item>
						<widget class="QPushButton" name="btnBrowse">
							<property name="text">
								<string>...</string>
							</property>
							<property name="toolTip">
								<string>Browse for a folder</string>
							</property>
							<property name="minimumWidth">
								<number>45</number>
							</property>
							<property name="maximumWidth">
								<number>45</number>
							</property>
						</widget>
					</item>

					<item>
						<spacer name="pathRightSpacer">
							<property name="orientation">
								<enum>Qt::Orientation::Horizontal</enum>
							</property>
							<property name="sizeHint" stdset="0">
								<size>
									<width>40</width>
									<height>20</height>
								</size>
							</property>
						</spacer>
					</item>
				</layout>
			</item>

			<!-- Spacing (mirrors Margin="0,30,0,0") -->
			<item>
				<spacer name="spacer3">
					<property name="orientation">
						<enum>Qt::Orientation::Vertical</enum>
					</property>
					<property name="sizeType">
						<enum>QSizePolicy::Policy::Fixed</enum>
					</property>
					<property name="sizeHint" stdset="0">
						<size>
							<width>20</width>
							<height>16</height>
						</size>
					</property>
				</spacer>
			</item>

			<!-- ── Row 4: Create button ──────────────────────────────────────── -->
			<!-- Mirrors: Button "Create" IsDefault="True" Width="96" -->
			<item>
				<layout class="QHBoxLayout" name="actionsRow">
					<property name="spacing">
						<number>8</number>
					</property>

					<item>
						<spacer name="actionsLeftSpacer">
							<property name="orientation">
								<enum>Qt::Orientation::Horizontal</enum>
							</property>
							<property name="sizeHint" stdset="0">
								<size>
									<width>40</width>
									<height>20</height>
								</size>
							</property>
						</spacer>
					</item>

					<!-- IsDefault="True" → setDefault(true) is called in the .cpp constructor -->
					<item>
						<widget class="QPushButton" name="btnCreate">
							<property name="text">
								<string>Create</string>
							</property>
							<property name="minimumWidth">
								<number>96</number>
							</property>
							<property name="maximumWidth">
								<number>96</number>
							</property>
							<!-- default is set programmatically; Qt requires the parent dialog context -->
						</widget>
					</item>

					<item>
						<spacer name="actionsRightSpacer">
							<property name="orientation">
								<enum>Qt::Orientation::Horizontal</enum>
							</property>
							<property name="sizeHint" stdset="0">
								<size>
									<width>40</width>
									<height>20</height>
								</size>
							</property>
						</spacer>
					</item>
				</layout>
			</item>

			<!-- Push content upward: vertical stretch at the bottom -->
			<item>
				<spacer name="bottomStretch">
					<property name="orientation">
						<enum>Qt::Orientation::Vertical</enum>
					</property>
					<property name="sizeHint" stdset="0">
						<size>
							<width>20</width>
							<height>40</height>
						</size>
					</property>
				</spacer>
			</item>

		</layout>
	</widget>
	<layoutdefault spacing="6" margin="11"/>
	<resources/>
	<connections/>
</ui>

